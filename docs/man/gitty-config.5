.RE
.SS "EXAMPLES"
.sp
.B Layout schema with all options and components
.br
.sp
.if n .RS 4
.nf
.fam C
{
   outputStyle\&    : \*(Aqcolumnar\*(Aq,
   executionMode\&  : \*(Aqparallel\*(Aq,
   countMode\&      : \*(Aqleading\*(Aq,
   maxCount\&       : 99,
   maxCountStyle\&  : { fg : \*(Aqmagenta\*(Aq, bg : \*(Aqgreen\*(Aq, styles : [ \*(Aqunderline\*(Aq, \*(Aqbold\*(Aq ] },
   aZSort\&         : true,
   sortOrder\&      : [ \*(Aqclean\*(Aq, \*(Aqrepo\*(Aq ],
   truncationMode : \*(Aqtail\*(Aq,
   components\&     : [
      { added\&       : { fg : \*(Aqext 214\*(Aq, bg : null, styles : null } },
      { copied\&      : { fg : null, bg : \*(Aqred\*(Aq, styles : [] } },
      { custom\&      : {
            command\&        : \*(Aqgit fetch > /dev/null 2>&1\*(Aq,
            sortID\&         : \*(Aqfetch\*(Aq,
            statusInput\&    : false,
            width\&          : 20,
            truncationMode : \*(Aqhead\*(Aq,
            fg\&             : null,
            bg\&             : null,
            styles\&         : []
         }
      },
      { deleted\&     : { fg : null, bg : null, styles : [] } },
      { detached\&    : { fg : null, bg : null, styles : [\*(Aqbold\*(Aq] } },
      { head\&        : {
            width\&          : 10,
            truncationMode : \*(Aqmiddle\*(Aq,
            fg\&             : \*(AqbrightGreen\*(Aq,
            bg\&             : null,
            styles\&         : [\*(Aqbold\*(Aq]
         }
      },
      { ignored\&     : { fg : \*(Aqrgb 200 112 3\*(Aq, bg : null, styles : null } },
      { locked\&      : { fg : \*(Aqhsb 300 0.4 0.2\*(Aq, bg : null, styles : null } },
      { modified\&    : { fg : \*(Aqhex #FFF\*(Aq, bg : null, styles : null } },
      { initialCommit : { fg : \*(Aqext 33\*(Aq, bg : null, styles : null } },
      { noUpstream\&  : { fg : \*(Aqred\*(Aq, bg : null, styles : null } },
      { oid\&         : { length : 10, fg : null, bg : null, styles : null } },
      { cleanOrDirty\&  : {
            showDirty\&   : true,
            cleanFg\&     : null,
            cleanBg\&     : null,
            cleanStyles : [],
            dirtyFg\&     : null,
            dirtyBg\&     : null,
            dirtyStyles : null
         }
      },
      { pull\&        : { hideCount : false , fg : null, bg : null, styles : null } },
      { push\&        : { hideCount : true , fg : null, bg : null, styles : null } },
      { renamed\&     : { fg : null, bg : null, styles : null } },
      { repo\&        : {
            width\&          : 10,
            truncationMode : null,
            fullPath\&       : true,
            fg\&             : null,
            bg\&             : null,
            styles\&         : null
         }
      },
      { separator\&   : { symbol : \*(Aq\-\-\*(Aq, fg : null, bg : null, styles : null } },
      { stashes\&     : { hideCount : null , fg : null, bg : null, styles : null } },
      { submodules\&  : {
            fg\&         : null,
            bg\&         : \*(Aqyellow\*(Aq,
            styles\&     : [\*(Aqblink\*(Aq, \*(Aqunderline\*(Aq],
            components : [
               { untracked : { fg : null, bg : null, styles : null } },
               { modified\&  : { fg : null, bg : null, styles : null } },
               { commit\&    : { fg : null, bg : null, styles : null } },
            ]
         }
      },
      { typeChange\&  : { fg : null, bg : null, styles : null } },
      { unmerged\&    : { fg : null, bg : null, styles : null } },
      { untracked\&   : { fg : null, bg : null, styles : null } },
      { upstream\&    : {
            width\&          : 20,
            truncationMode : \*(Aqhead\*(Aq,
            fg\&             : null,
            bg\&             : null,
            styles\&         : null
         }
      },
   ],
   symbols\&        : {
      added\&         : \*(AqA\*(Aq,
      clean\&         : \*(Aq✓\*(Aq,
      copied\&        : \*(AqC\*(Aq,
      deleted\&       : \*(AqD\*(Aq,
      detached\&      : \*(Aq⍜\*(Aq,
      dirty\&         : \*(Aq*\*(Aq,
      ignored\&       : \*(Aq!\*(Aq,
      initialCommit : \*(AqI\*(Aq,
      locked\&        : \*(AqL\*(Aq,
      modified\&      : \*(AqM\*(Aq,
      noUpstream\&    : \*(Aq⇞\*(Aq,
      pull\&          : \*(Aq↓\*(Aq,
      push\&          : \*(Aq↑\*(Aq,
      renamed\&       : \*(AqR\*(Aq,
      separator\&     : \*(Aq \*(Aq,
      stashes\&       : \*(Aq#\*(Aq,
      typeChange\&    : \*(AqT\*(Aq,
      truncator\&     : \*(Aq…\*(Aq,
      unmerged\&      : \*(AqU\*(Aq,
      untracked\&     : \*(Aq?\*(Aq,
      submodule\&     : {
         prefix\&       : \*(Aq<\*(Aq,
         commit\&       : \*(AqC\*(Aq,
         modified\&     : \*(AqM\*(Aq,
         untracked\&    : \*(Aq?\*(Aq,
         suffix\&       : \*(Aq>\*(Aq,
      },
   },
}
.fam
.fi
